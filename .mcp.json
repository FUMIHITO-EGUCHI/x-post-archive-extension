{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "node_modules\\.bin\\chrome-devtools-mcp.cmd",
      "args": [
        "--browser-url=http://127.0.0.1:9223",
        "--no-usage-statistics"
      ],
      "env": {
        "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS": "1"
      }
    },
    "github": {
      "type": "stdio",
      "command": "scripts\\github-mcp-stdio.cmd"
    }
  }
}
