#!/bin/sh
# commit-msg hook

HOOK_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
node "$HOOK_DIR/../workflow-guard/check-commit-message.mjs" "$1"
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "commit-msg hook failed."
  echo "Amend the commit message to include a GitHub Issue reference (e.g. #42)"
  echo "or add [skip-issue] for trivial changes."
  exit 1
fi

exit 0
